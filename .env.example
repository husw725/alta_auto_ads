# --- Meta Ads API Config ---
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=act_your_account_id
META_PAGE_ID=your_page_id
META_PIXEL_ID=your_pixel_id
META_APP_LINK=https://apps.apple.com/app/idxxxxxx
META_BASE_URL=https://graph.facebook.com/v21.0

# --- Mobvista XMP API Config ---
XMP_CLIENT_ID=your_xmp_id
XMP_CLIENT_SECRET=your_xmp_secret

# --- AI Model Config (Optional) ---
# For Semantic Match and Copywriting
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- System Config ---
STREAMLIT_SERVER_PORT=8501
